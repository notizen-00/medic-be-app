APP_NAME="Medic App"
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://staging.example.com

LOG_CHANNEL=stack
LOG_LEVEL=debug

FORCE_HTTPS=true
SESSION_SECURE_COOKIE=true

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=medic_app_staging
DB_USERNAME=medic
DB_PASSWORD=change-me

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

VITE_APP_NAME="${APP_NAME}"
