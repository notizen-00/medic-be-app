{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^13.0",
        "laravel/reverb": "^1.10",
        "laravel/sanctum": "^4.3",
        "laravel/tinker": "^3.0",
        "midtrans/midtrans-php": "^2.6"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/boost": "^2.4",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.6",
        "pestphp/pest-plugin-laravel": "^4.1",
        "yasin_tgh/laravel-postman": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"npm run dev\" --names='server,queue,vite'"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "test:feature": [
            "@php artisan config:clear --ansi",
            "@php artisan test tests/Feature"
        ],
        "test:module": [
            "@php artisan config:clear --ansi",
            "@php artisan test tests/Feature/Modules"
        ],
        "test:module:admin": [
            "@php artisan config:clear --ansi",
            "@php artisan test tests/Feature/Modules/Admin"
        ],
        "test:module:auth": [
            "@php artisan config:clear --ansi",
            "@php artisan test tests/Feature/Modules/Auth"
        ],
        "test:module:consultation": [
            "@php artisan config:clear --ansi",
            "@php artisan test tests/Feature/Modules/Consultation"
        ],
        "test:module:mitra": [
            "@php artisan config:clear --ansi",
            "@php artisan test tests/Feature/Modules/Mitra"
        ],
        "test:module:order": [
            "@php artisan config:clear --ansi",
            "@php artisan test tests/Feature/Modules/Order"
        ],
        "test:module:patient": [
            "@php artisan config:clear --ansi",
            "@php artisan test tests/Feature/Modules/Patient"
        ],
        "test:module:pharmacy": [
            "@php artisan config:clear --ansi",
            "@php artisan test tests/Feature/Modules/Pharmacy"
        ],
        "test:module:service-booking": [
            "@php artisan config:clear --ansi",
            "@php artisan test tests/Feature/Modules/ServiceBooking"
        ],
        "test:module:shared": [
            "@php artisan config:clear --ansi",
            "@php artisan test tests/Feature/Modules/Shared"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
